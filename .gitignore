# ===========================================
# ConsultaCheck API - Gitignore
# ===========================================

# Dependencias
node_modules/

# Build / compilación
dist/
build/
*.tsbuildinfo

# Variables de entorno (NUNCA subir credenciales)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local

# Mantener .env.example como plantilla (no ignorar)

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cobertura y tests
coverage/
.nyc_output/
*.lcov

# Sistema operativo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editores
.idea/
.vscode/
*.swp
*.swo
*~

# Certificados y claves (nunca subir)
*.pem
*.key
*.crt
*.p12

# Binarios generados
*.exe
*.exe~
*.dll
*.so
*.dylib
*.out

# Temporal y cache
.temp/
tmp/
temp/
.cache/
