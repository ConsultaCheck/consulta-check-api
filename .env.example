# Base de datos
MONGODB_URI=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/
MONGODB_DB=consultacheck

# Servidor
PORT=4000
NODE_ENV=development

# Seguridad (obligatorio en producción)
JWT_SECRET=una-clave-larga-y-aleatoria-cambiar-en-produccion

# CORS (producción): URL del frontend separada por comas si hay varias
# Ejemplo: https://consultacheck.vercel.app
CORS_ORIGIN=
